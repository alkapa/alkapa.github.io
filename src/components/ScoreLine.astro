---
// G1 — Línea-batuta: canvas tipo osciloscopio / partitura.
// En reposo, calma; reacciona a la velocidad de scroll y al puntero (la "energía"
// del director). Con prefers-reduced-motion dibuja una onda estática y no anima.
---

<div class="scoreline" aria-hidden="true">
  <canvas data-scoreline></canvas>
</div>

<style>
  .scoreline {
    width: 100%;
    height: 60px;
    margin-block: clamp(8px, 1.6vh, 18px);
  }
  .scoreline canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const wrap = document.querySelector<HTMLElement>('.scoreline');
  const canvas = document.querySelector<HTMLCanvasElement>('canvas[data-scoreline]');
  const ctx = canvas?.getContext('2d');

  if (wrap && canvas && ctx) {
    const motion = document.documentElement.classList.contains('js-motion');
    const ink = '19, 32, 31';
    const gold = '233, 178, 74';

    let w = 0;
    let h = 0;
    let dpr = 1;
    let energy = 0; // 0..1 — entusiasmo del director
    let phase = 0;
    let batonX = 0.5; // posición relativa 0..1 de la batuta
    let batonTarget = 0.5;
    let lastScroll = window.scrollY;

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = wrap!.clientWidth;
      h = wrap!.clientHeight;
      canvas!.width = Math.round(w * dpr);
      canvas!.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function wave(x: number, amp: number) {
      const k1 = (2 * Math.PI) / Math.max(w, 1);
      // dos armónicos: cuerpo + detalle
      return (
        amp *
        (Math.sin(x * k1 * 2 + phase) * 0.62 +
          Math.sin(x * k1 * 5 + phase * 1.7) * 0.3 +
          Math.sin(x * k1 * 9 - phase * 0.6) * 0.12)
      );
    }

    function draw() {
      ctx!.clearRect(0, 0, w, h);
      const mid = h / 2;
      const baseAmp = h * 0.05;
      const amp = baseAmp + energy * h * 0.32;

      // marcas de compás (bar lines)
      const step = 86;
      ctx!.strokeStyle = `rgba(${ink}, 0.10)`;
      ctx!.lineWidth = 1;
      for (let x = step / 2; x < w; x += step) {
        ctx!.beginPath();
        ctx!.moveTo(x + 0.5, mid - 5);
        ctx!.lineTo(x + 0.5, mid + 5);
        ctx!.stroke();
      }

      // la onda
      ctx!.beginPath();
      const bx = batonX * w;
      for (let x = 0; x <= w; x += 2) {
        // la batuta excita localmente la zona cercana
        const local = 1 + 0.9 * Math.exp(-((x - bx) ** 2) / (2 * 70 ** 2));
        const y = mid + wave(x, amp * local);
        if (x === 0) ctx!.moveTo(x, y);
        else ctx!.lineTo(x, y);
      }
      ctx!.strokeStyle = `rgba(${ink}, ${0.22 + energy * 0.18})`;
      ctx!.lineWidth = 1.4;
      ctx!.stroke();

      // la batuta (punto + brillo oro)
      const by = mid + wave(bx, amp * 1.9);
      const glow = ctx!.createRadialGradient(bx, by, 0, bx, by, 26);
      glow.addColorStop(0, `rgba(${gold}, ${0.5 + energy * 0.4})`);
      glow.addColorStop(1, `rgba(${gold}, 0)`);
      ctx!.fillStyle = glow;
      ctx!.beginPath();
      ctx!.arc(bx, by, 26, 0, Math.PI * 2);
      ctx!.fill();
      ctx!.fillStyle = `rgba(${gold}, 0.95)`;
      ctx!.beginPath();
      ctx!.arc(bx, by, 2.6, 0, Math.PI * 2);
      ctx!.fill();
    }

    function staticDraw() {
      // estado en reposo (reduced-motion): onda suave, batuta centrada.
      phase = 0.6;
      energy = 0.12;
      batonX = 0.5;
      draw();
    }

    let autoSweep = 0;
    function frame() {
      phase += 0.012 + energy * 0.05;
      energy *= 0.945;
      if (energy < 0.001) energy = 0;
      // si nadie mueve el puntero, la batuta barre lento
      autoSweep += 0.004;
      batonTarget = 0.5 + Math.sin(autoSweep) * 0.42;
      batonX += (batonTarget - batonX) * 0.05;
      draw();
      requestAnimationFrame(frame);
    }

    function bump(amount: number) {
      energy = Math.min(1, energy + amount);
    }

    const ro = new ResizeObserver(() => {
      resize();
      if (!motion) staticDraw();
    });
    ro.observe(wrap);
    resize();

    if (motion) {
      window.addEventListener(
        'scroll',
        () => {
          const dy = Math.abs(window.scrollY - lastScroll);
          lastScroll = window.scrollY;
          bump(Math.min(0.5, dy / 90));
        },
        { passive: true },
      );
      window.addEventListener(
        'pointermove',
        (e) => {
          const r = wrap.getBoundingClientRect();
          batonTarget = Math.max(0, Math.min(1, (e.clientX - r.left) / Math.max(r.width, 1)));
          batonX += (batonTarget - batonX) * 0.25;
          bump(0.04);
        },
        { passive: true },
      );
      requestAnimationFrame(frame);
    } else {
      staticDraw();
    }
  }
</script>
